{
  "name": "polito-tools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Polito Tools - a comprehensive learn/practice/exam hub for Politecnico di Torino mechanical engineering courses.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "verify:excel": "node scripts/verify-excel-engine.mjs",
    "verify:labs": "node scripts/verify-labs.mjs",
    "verify:srs": "node scripts/verify-srs.mjs",
    "verify": "node scripts/verify-excel-engine.mjs && node scripts/verify-labs.mjs && node scripts/verify-srs.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "katex": "^0.16.11",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/katex": "^0.16.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
